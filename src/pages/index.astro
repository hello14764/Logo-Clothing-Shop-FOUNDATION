---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';
import CTABand from '@/components/CTABand.astro';
import HomeHero from '@/components/HomeHero.astro';
import ReviewsBand from '@/components/ReviewsBand.astro';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import ThreadDivider from '@/components/ThreadDivider.astro';
---

<BaseLayout
  title="Corporate Gifting Michigan"
  description="Curated corporate gifting programs produced in-house in Michigan. Embroidery, screen printing, and full-color decoration. Plan a Gifting Program with Logo Clothing Shop."
>
  <HomeHero />

  <ThreadDivider />

  <section class="border-y border-stone/25 bg-white/60 py-8 backdrop-blur-sm">
    <div class="container-content">
      <p class="mb-4 text-center text-xs font-semibold uppercase tracking-[0.12em] text-muted">
        Trusted by marketing teams across Michigan
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-2 text-sm font-medium text-navy/80 sm:text-base">
        <span>Construction</span>
        <span class="text-gold" aria-hidden="true">·</span>
        <span>Legal &amp; Finance</span>
        <span class="text-gold" aria-hidden="true">·</span>
        <span>Insurance</span>
        <span class="text-gold hidden sm:inline" aria-hidden="true">·</span>
        <span class="hidden sm:inline">Manufacturing</span>
        <span class="hidden text-gold sm:inline" aria-hidden="true">·</span>
        <span class="hidden sm:inline">Technology</span>
      </div>
    </div>
  </section>

  <Section>
    <SectionHeader
      eyebrow="The problem"
      title="You don't need another promo catalog"
      description="You need a partner who learns your culture, curates the right items, produces them in-house, and handles delivery. Your gifts should feel personal, not like leftover swag."
      accent
    />
  </Section>

  <Section tone="alt">
    <SectionHeader
      eyebrow="Programs"
      title="Gifting programs we build"
      description="Curated packages for the moments that matter to your organization."
      centered
    />
    <div class="grid gap-6 md:grid-cols-3">
      <Card title="Employee appreciation">
        <p>Welcome kits, work anniversaries, team recognition, and milestone programs tailored to your culture and brand.</p>
        <a href="/corporate-gifting/#occasions" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-navy no-underline hover:text-gold-dark">
          Learn more
          <span aria-hidden="true">→</span>
        </a>
      </Card>
      <Card title="Client &amp; referral gifting">
        <p>Thank-yous that reflect your standards. Understated for law and finance, bold when your brand calls for it.</p>
        <a href="/corporate-gifting/#occasions" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-navy no-underline hover:text-gold-dark">
          Learn more
          <span aria-hidden="true">→</span>
        </a>
      </Card>
      <Card title="Holiday &amp; ship-to-home">
        <p>One program, many addresses. We handle curation, production, packaging, and delivery nationwide.</p>
        <a href="/corporate-gifting/#occasions" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-navy no-underline hover:text-gold-dark">
          Learn more
          <span aria-hidden="true">→</span>
        </a>
      </Card>
    </div>
  </Section>

  <Section>
    <SectionHeader
      eyebrow="Process"
      title="How it works"
      description="A consultative process from first conversation to delivered gifts."
    />
    <ol class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        [
          ['Discover', 'We learn your goals, recipients, brand standards, and timeline.'],
          ['Curate', 'Packages tailored to your budget and audience. Not a catalog dump.'],
          ['Produce', 'Embroidery, screen print, and decoration in-house at our Michigan shop.'],
          ['Deliver', 'Single location or ship-to-home. One point of contact start to finish.'],
        ].map(([step, copy], i) => (
          <li class="surface-card-hover relative pt-8">
            <span class="absolute left-6 top-0 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full border border-gold/30 bg-white font-display text-lg font-semibold text-gold-dark shadow-soft">
              {i + 1}
            </span>
            <h3 class="mb-2 text-xl">{step}</h3>
            <p class="text-sm leading-relaxed text-muted">{copy}</p>
          </li>
        ))
      }
    </ol>
    <div class="mt-10 text-center sm:text-left">
      <Button href="/how-it-works/" variant="secondary">See the full process</Button>
    </div>
  </Section>

  <Section tone="alt">
    <SectionHeader
      eyebrow="Proof"
      title="Featured work"
      description="Client gifting at scale for a Michigan aerospace manufacturer."
    />
    <Card tag="Manufacturing · Client Gifting" title="Weldaloy" featured>
      <p>
        300 custom solar chargers to every client. Norm called back: "Can we get any more? People loved the gifts." Follow-on order: 500 premium cable kits shipped to France.
      </p>
      <a href="/case-studies/weldaloy-client-gifting/" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-navy no-underline hover:text-gold-dark">
        Read case study
        <span aria-hidden="true">→</span>
      </a>
    </Card>
  </Section>

  <Section>
    <SectionHeader eyebrow="Why us" title="The consultative difference" centered />
    <div class="grid gap-6 md:grid-cols-3">
      <Card title="Deep discovery">
        <p>We get to know your organization, recipients, and goals before recommending a single item.</p>
      </Card>
      <Card title="Curated packages">
        <p>Thoughtful selections aligned to your brand. Never a one-size-fits-all catalog.</p>
      </Card>
      <Card title="One partner">
        <p>Strategy, design, production, and delivery under one roof. One point of contact.</p>
      </Card>
    </div>
  </Section>

  <Section tone="alt">
    <SectionHeader
      eyebrow="Capability"
      title="Craft you can see and feel"
      description="Every gifting program is backed by in-house production in Birmingham. Embroidery, screen printing, web store programs, and promotional products. Not outsourced to a decorator you've never met."
      centered
    />
  </Section>

  <ReviewsBand />

  <CTABand
    title="Ready to plan your next gifting program?"
    description="Let's talk about your team, your clients, and the impression you want to make. No pressure. Just a conversation to see if we're a fit."
  />
</BaseLayout>
