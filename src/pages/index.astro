---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';
import CTABand from '@/components/CTABand.astro';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import ThreadDivider from '@/components/ThreadDivider.astro';
---

<BaseLayout
  title="Corporate Gifting Michigan"
  description="Curated corporate gifting programs produced in-house in Michigan. Embroidery, screen printing, and full-color decoration. Plan a Gifting Program with Logo Clothing Shop."
>
  <section class="bg-white py-16 sm:py-24">
    <div class="container-content grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="mb-4 text-xs font-semibold uppercase tracking-[0.12em] text-gold">
          Michigan · Corporate Gifting
        </p>
        <h1 class="mb-5 text-4xl sm:text-5xl lg:text-6xl">Corporate gifting that feels intentional</h1>
        <p class="mb-4 text-lg text-muted">
          Curated programs for teams and clients. Designed, embroidered, and delivered in-house from the Detroit area.
        </p>
        <p class="mb-8 text-sm text-muted">
          In-house embroidery · screen printing · full-color decoration
        </p>
        <div class="flex flex-wrap gap-3">
          <Button href="/contact/">Plan a Gifting Program</Button>
          <Button href="/how-it-works/" variant="secondary">See How It Works</Button>
        </div>
      </div>
      <div class="flex min-h-[280px] items-center justify-center rounded-lg border border-dashed border-stone bg-stone/20 p-8 text-center text-muted">
        Package photography coming soon
      </div>
    </div>
  </section>

  <ThreadDivider />

  <section class="border-y border-stone/30 bg-stone/20 py-6">
    <div class="container-content text-center text-sm font-medium text-muted">
      Trusted across construction · legal &amp; finance · insurance · technology
    </div>
  </section>

  <Section>
    <SectionHeader
      title="You don't need another promo catalog"
      description="You need a partner who learns your culture, curates the right items, produces them in-house, and handles delivery. Your gifts should feel personal, not like leftover swag."
    />
  </Section>

  <Section tone="alt">
    <SectionHeader
      title="Gifting programs we build"
      description="Curated packages for the moments that matter to your organization."
      centered
    />
    <div class="grid gap-6 md:grid-cols-3">
      <Card title="Employee appreciation">
        <p>Welcome kits, work anniversaries, team recognition, and milestone programs tailored to your culture and brand.</p>
        <a href="/corporate-gifting/#occasions" class="mt-4 inline-block text-sm font-semibold text-navy no-underline hover:text-navy-light">Learn more</a>
      </Card>
      <Card title="Client &amp; referral gifting">
        <p>Thank-yous that reflect your standards. Understated for law and finance, bold when your brand calls for it.</p>
        <a href="/corporate-gifting/#occasions" class="mt-4 inline-block text-sm font-semibold text-navy no-underline hover:text-navy-light">Learn more</a>
      </Card>
      <Card title="Holiday &amp; ship-to-home">
        <p>One program, many addresses. We handle curation, production, packaging, and delivery nationwide.</p>
        <a href="/corporate-gifting/#occasions" class="mt-4 inline-block text-sm font-semibold text-navy no-underline hover:text-navy-light">Learn more</a>
      </Card>
    </div>
  </Section>

  <Section>
    <SectionHeader
      title="How it works"
      description="A consultative process from first conversation to delivered gifts."
    />
    <ol class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        [
          ['Discover', 'We learn your goals, recipients, brand standards, and timeline.'],
          ['Curate', 'Packages tailored to your budget and audience. Not a catalog dump.'],
          ['Produce', 'Embroidery, screen print, and decoration in-house at our Michigan shop.'],
          ['Deliver', 'Single location or ship-to-home. One point of contact start to finish.'],
        ].map(([step, copy], i) => (
          <li class="rounded-lg border border-stone/50 bg-white p-6">
            <span class="mb-3 inline-flex h-8 w-8 items-center justify-center rounded-full bg-gold/20 text-sm font-semibold text-gold-dark">
              {i + 1}
            </span>
            <h3 class="mb-2 text-xl">{step}</h3>
            <p class="text-muted">{copy}</p>
          </li>
        ))
      }
    </ol>
    <div class="mt-10">
      <Button href="/how-it-works/" variant="secondary">See the full process</Button>
    </div>
  </Section>

  <Section tone="alt">
    <SectionHeader
      title="Featured work"
      description="Client gifting at scale for a Michigan aerospace manufacturer."
    />
    <Card tag="Manufacturing · Client Gifting" title="Weldaloy">
      <p>
        300 custom solar chargers to every client. Norm called back: "Can we get any more? People loved the gifts." Follow-on order: 500 premium cable kits shipped to France.
      </p>
      <a href="/case-studies/weldaloy-client-gifting/" class="mt-4 inline-block text-sm font-semibold text-navy no-underline hover:text-navy-light">Read case study</a>
    </Card>
  </Section>

  <Section>
    <SectionHeader title="The consultative difference" centered />
    <div class="grid gap-6 md:grid-cols-3">
      <Card title="Deep discovery">
        <p>We get to know your organization, recipients, and goals before recommending a single item.</p>
      </Card>
      <Card title="Curated packages">
        <p>Thoughtful selections aligned to your brand. Never a one-size-fits-all catalog.</p>
      </Card>
      <Card title="One partner">
        <p>Strategy, design, production, and delivery under one roof. One point of contact.</p>
      </Card>
    </div>
  </Section>

  <Section tone="alt">
    <SectionHeader
      title="Craft you can see and feel"
      description="Every gifting program is backed by in-house production in Birmingham. Embroidery, screen printing, full-color decoration, and promotional products. Not outsourced to a decorator you've never met."
    />
  </Section>

  <CTABand
    title="Ready to plan your next gifting program?"
    description="Let's talk about your team, your clients, and the impression you want to make."
  />
</BaseLayout>
