---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import CTABand from '@/components/CTABand.astro';
import PageHero from '@/components/PageHero.astro';
import Section from '@/components/Section.astro';
import { site } from '@/lib/site';
---

<BaseLayout
  title="How It Works"
  description="Our corporate gifting process: discover, curate, produce in-house, and deliver. One partner from first call to finished gifts in Michigan."
>
  <PageHero
    title="How it works"
    lead="A consultative process from first conversation to delivered gifts. One partner, one point of contact."
  />

  <Section>
    <ol class="grid gap-6 md:grid-cols-2">
      {
        [
          ['Discover', 'We start with a conversation about your goals, recipients, brand standards, budget, and timeline. No catalog browsing required.'],
          ['Curate', 'We put together package options tailored to your organization. You review, refine, and approve before anything goes into production.'],
          ['Produce', 'Embroidery, screen printing, and full-color decoration happen in-house at our Michigan shop. Quality and brand execution stay under our control.'],
          ['Deliver', "Single-site delivery or ship-to-home for distributed teams and holiday programs. We coordinate logistics so you don't have to."],
        ].map(([step, copy], i) => (
          <li class="rounded-lg border border-stone/50 bg-white p-6">
            <span class="mb-3 inline-flex h-8 w-8 items-center justify-center rounded-full bg-gold/20 text-sm font-semibold text-gold-dark">
              {i + 1}
            </span>
            <h3 class="mb-2 text-xl">{step}</h3>
            <p class="text-muted">{copy}</p>
          </li>
        ))
      }
    </ol>
  </Section>

  <Section tone="alt">
    <div class="prose-wide">
      <h2>What we need from you</h2>
      <ul>
        <li>A sense of who receives the gifts and what occasion you're marking</li>
        <li>Budget range and approximate quantity</li>
        <li>Your logo and brand guidelines (if available)</li>
        <li>Target delivery date</li>
      </ul>
      <p>Don't have everything figured out? That's what the discovery call is for.</p>
    </div>
  </Section>

  <Section>
    <div class="prose-wide">
      <h2>What you can expect</h2>
      <ul>
        <li>One dedicated point of contact throughout the program</li>
        <li>Clear timelines before production begins</li>
        <li>Samples when the project calls for them</li>
        <li>Transparent communication. No chasing multiple vendors.</li>
      </ul>
    </div>
  </Section>

  <CTABand
    title="Ready to get started?"
    description="Book a curation call and we'll walk through your first program together."
  >
    <p class="mt-6">
      <a
        href={site.bookingUrl}
        class="inline-flex items-center justify-center rounded-md border border-white/40 px-5 py-2.5 text-sm font-semibold text-white no-underline hover:border-white hover:bg-white/10"
      >
        Or book directly on HubSpot
      </a>
    </p>
  </CTABand>
</BaseLayout>
