---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import PageHero from '@/components/PageHero.astro';
import Section from '@/components/Section.astro';
import { site } from '@/lib/site';
---

<BaseLayout
  title="Plan a Gifting Program"
  description="Contact Logo Clothing Shop to plan a corporate gifting program. Michigan-based, in-house embroidery and screen printing. Birmingham, MI."
>
  <PageHero
    title="Plan a Gifting Program"
    lead="Tell us about your team, your clients, and the impression you want to make. We'll follow up to schedule a curation call."
  />

  <Section>
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h3 class="mb-3 text-2xl">{site.name}</h3>
        <p class="mb-4 text-muted">Corporate gifting and in-house decoration. Serving companies across Michigan and beyond.</p>
        <p class="mb-4"><strong>Joe Toma</strong><br />Business Development Director</p>
        <p class="mb-4 text-muted">
          {site.address.street}<br />
          {site.address.city}
        </p>
        <p class="mb-6">
          <a href={`mailto:${site.email}`} class="text-navy hover:text-navy-light">{site.email}</a><br />
          <a href={site.phoneOfficeHref} class="text-navy hover:text-navy-light">{site.phoneOffice}</a> office<br />
          <a href={site.phoneCellHref} class="text-navy hover:text-navy-light">{site.phoneCell}</a> cell
        </p>
        <Button href={site.bookingUrl}>Book an introductory call</Button>
        <p class="mt-6 text-sm italic text-muted">{site.footerBridge}</p>
      </div>

      <form class="space-y-5 rounded-lg border border-stone/60 bg-white p-6 shadow-sm" action="#" method="post">
        <!-- Connect to Netlify Forms, Formspree, or similar at deploy time -->
        <div>
          <label for="name" class="mb-1.5 block text-sm font-medium">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-md border border-stone/60 bg-warm-gray px-3 py-2.5 focus:border-navy focus:outline-none"
          />
        </div>
        <div>
          <label for="company" class="mb-1.5 block text-sm font-medium">Company</label>
          <input
            type="text"
            id="company"
            name="company"
            required
            autocomplete="organization"
            class="w-full rounded-md border border-stone/60 bg-warm-gray px-3 py-2.5 focus:border-navy focus:outline-none"
          />
        </div>
        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-md border border-stone/60 bg-warm-gray px-3 py-2.5 focus:border-navy focus:outline-none"
          />
        </div>
        <div>
          <label for="phone" class="mb-1.5 block text-sm font-medium">
            Phone <span class="text-muted">(optional)</span>
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            autocomplete="tel"
            class="w-full rounded-md border border-stone/60 bg-warm-gray px-3 py-2.5 focus:border-navy focus:outline-none"
          />
        </div>
        <div>
          <label for="interest" class="mb-1.5 block text-sm font-medium">I'm interested in</label>
          <select
            id="interest"
            name="interest"
            required
            class="w-full rounded-md border border-stone/60 bg-warm-gray px-3 py-2.5 focus:border-navy focus:outline-none"
          >
            <option value="">Select one</option>
            <option value="gifting">Corporate gifting program</option>
            <option value="employee">Employee appreciation</option>
            <option value="client">Client appreciation</option>
            <option value="holiday">Holiday / ship-to-home</option>
            <option value="production">Production / promo project</option>
            <option value="other">Not sure yet</option>
          </select>
        </div>
        <div>
          <label for="message" class="mb-1.5 block text-sm font-medium">Tell us about your project</label>
          <textarea
            id="message"
            name="message"
            placeholder="Occasion, approximate quantity, timeline, industry…"
            class="min-h-[120px] w-full rounded-md border border-stone/60 bg-warm-gray px-3 py-2.5 focus:border-navy focus:outline-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-md border border-navy bg-navy px-5 py-2.5 text-sm font-semibold text-white hover:bg-navy-dark"
        >
          Plan a Gifting Program
        </button>
      </form>
    </div>
  </Section>
</BaseLayout>
