---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CaseStudyCard from '@/components/CaseStudyCard.astro';
import CTABand from '@/components/CTABand.astro';
import PageHero from '@/components/PageHero.astro';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { getCaseStudiesByGroup, getFeaturedCaseStudies } from '@/lib/caseStudies';

const featured = getFeaturedCaseStudies();
const byGroup = getCaseStudiesByGroup();
---

<BaseLayout
  title="Case Studies"
  description="Case studies in corporate gifting, embroidery, and branded apparel. Michigan companies trust Logo Clothing Shop."
>
  <PageHero
    tag="Resources"
    title="Case studies"
    lead="Curated gifting, precision embroidery, and branded programs. Real work for Michigan organizations."
    visual
  />

  <Section>
    <SectionHeader
      eyebrow="Featured"
      title="Proof that matters"
      description="Gifting, law, nonprofit, and trades. A sample of how we partner with clients."
    />
    <div class="grid gap-6 md:grid-cols-2">
      {featured.map((study) => <CaseStudyCard study={study} />)}
    </div>
  </Section>

  <Section tone="alt">
    {
      [...byGroup.entries()].map(([group, studies]) => (
        <div class="mb-14 last:mb-0">
          <h2 class="mb-6 flex items-center gap-3 text-2xl text-navy">
            <span class="h-px w-8 bg-gold/60" aria-hidden="true"></span>
            {group}
          </h2>
          <div class="grid gap-6 md:grid-cols-3">
            {studies.map((study) => (
              <CaseStudyCard study={study} />
            ))}
          </div>
        </div>
      ))
    }
  </Section>

  <CTABand
    title="Your story could be next"
    description="Tell us about your team, event, or gifting program."
  />
</BaseLayout>
