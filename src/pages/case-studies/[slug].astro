---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABand from '@/components/CTABand.astro';
import ImagePlaceholder from '@/components/ImagePlaceholder.astro';
import PageHero from '@/components/PageHero.astro';
import QuoteBlock from '@/components/QuoteBlock.astro';
import Section from '@/components/Section.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { caseStudies, renderList } from '@/lib/caseStudies';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (() => {
  return caseStudies.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}) satisfies GetStaticPaths;

const { study } = Astro.props;
---

<BaseLayout title={`${study.title} | Case Study`} description={study.summary.slice(0, 155)}>
  <PageHero title={study.title} lead={study.summary} tag={study.category} visual />

  <Section>
    <div class="grid gap-12 lg:grid-cols-[1fr_280px]">
      <div class="prose-section space-y-10">
        <div>
          <h2>Client</h2>
          <p>{study.client}</p>
        </div>
        <div>
          <h2>Goal</h2>
          <p>{study.goal}</p>
        </div>
        <div>
          <h2>Challenge</h2>
          <ul>
            {renderList(study.challenge).map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div>
          <h2>Solution</h2>
          <ul>
            {renderList(study.solution).map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div>
          <h2>Result</h2>
          <ul>
            {renderList(study.result).map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div>
          <h2>Key takeaway</h2>
          <p>{study.takeaway}</p>
        </div>
        {
          study.note && (
            <p class="text-sm text-muted">Note: {study.note}</p>
          )
        }
      </div>
      <aside class="space-y-6">
        <ImagePlaceholder variant="square" label="Case study photo coming soon" />
        {
          study.quote?.text ? (
            <QuoteBlock text={study.quote.text} name={study.quote.name} title={study.quote.title} />
          ) : (
            <QuoteBlock placeholder />
          )
        }
      </aside>
    </div>
  </Section>

  <CTABand
    title="Ready to plan your next program?"
    description="Let's talk about what you're building, gifting, apparel, or both."
  />
</BaseLayout>
