---
import ImagePlaceholder from './ImagePlaceholder.astro';
import type { CaseStudy } from '@/types/caseStudy';

interface Props {
  study: CaseStudy;
  featured?: boolean;
}

const { study, featured = false }: Props = Astro.props;
---

<article class:list={['surface-card-hover overflow-hidden p-0', featured && 'md:col-span-1']}>
  <ImagePlaceholder variant="card" class="rounded-none border-0 shadow-none" />
  <div class="p-6">
    <p class="mb-2 eyebrow">{study.category}</p>
    <h3 class="mb-3 text-xl">
      <a href={`/case-studies/${study.slug}/`} class="text-navy no-underline hover:text-gold-dark">
        {study.title}
      </a>
    </h3>
    <p class="mb-4 text-sm leading-relaxed text-muted">{study.summary}</p>
    <a
      href={`/case-studies/${study.slug}/`}
      class="inline-flex items-center gap-1 text-sm font-semibold text-navy no-underline hover:text-gold-dark"
    >
      Read case study <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
