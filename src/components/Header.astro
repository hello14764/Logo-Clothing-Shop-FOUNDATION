---
import Button from './Button.astro';
import { navLinks, site } from '@/lib/site';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-stone/30 bg-warm-gray/95 backdrop-blur">
  <div class="container-content flex h-20 items-center justify-between gap-4">
    <div class="min-w-0">
      <a href="/" class="inline-block leading-none no-underline">
        <img
          src="/images/general/logo-clothing-shop.svg"
          alt={site.name}
          class="h-11 w-auto sm:h-12"
          width="200"
          height="60"
        />
      </a>
      <span class="mt-0.5 block text-[0.625rem] font-medium uppercase tracking-wider text-muted sm:text-[0.6875rem]">
        {site.bridge}
      </span>
    </div>

    <button
      type="button"
      class="nav-toggle flex h-10 w-10 flex-col items-center justify-center gap-1.5 rounded-md border border-stone/50 bg-white lg:hidden"
      aria-expanded="false"
      aria-controls="main-nav"
      aria-label="Toggle navigation"
    >
      <span class="block h-0.5 w-5 bg-navy"></span>
      <span class="block h-0.5 w-5 bg-navy"></span>
      <span class="block h-0.5 w-5 bg-navy"></span>
    </button>

    <nav
      id="main-nav"
      class="main-nav absolute left-0 right-0 top-full hidden border-b border-stone/30 bg-warm-gray px-5 py-4 lg:static lg:flex lg:flex-1 lg:items-center lg:justify-end lg:gap-8 lg:border-0 lg:bg-transparent lg:p-0"
      aria-label="Main"
    >
      <ul class="mb-4 space-y-2 lg:mb-0 lg:flex lg:items-center lg:gap-6">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'block py-2 text-sm font-medium no-underline lg:py-0',
                  currentPath.startsWith(href)
                    ? 'text-navy'
                    : 'text-ink hover:text-navy-light',
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="lg:hidden">
        <Button href="/contact/">Plan a Gifting Program</Button>
      </div>
    </nav>

    <div class="hidden lg:block">
      <Button href="/contact/">Plan a Gifting Program</Button>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var toggle = document.querySelector('.nav-toggle');
    var nav = document.querySelector('.main-nav');
    if (!toggle || !nav) return;

    toggle.addEventListener('click', function () {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('hidden');
      nav.classList.toggle('block');
    });

    nav.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.add('hidden');
        nav.classList.remove('block');
      });
    });
  })();
</script>

<style>
  @media (min-width: 1024px) {
    .main-nav {
      display: flex !important;
    }
  }
</style>
