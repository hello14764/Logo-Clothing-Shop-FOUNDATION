---
import Button from './Button.astro';
import NavDropdown from './NavDropdown.astro';
import { navDropdowns, navPrimary, site } from '@/lib/site';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-stone/25 bg-warm-gray/90 shadow-header backdrop-blur-md">
  <div class="container-content flex h-20 items-center justify-between gap-4">
    <div class="min-w-0 shrink-0">
      <a href="/" class="inline-block leading-none no-underline">
        <img
          src="/images/general/logo-clothing-shop.svg"
          alt={site.name}
          class="h-11 w-auto sm:h-12"
          width="200"
          height="60"
        />
      </a>
      <span class="mt-1 block text-[0.625rem] font-medium uppercase tracking-[0.08em] text-muted sm:text-[0.6875rem]">
        {site.bridge}
      </span>
    </div>

    <button
      type="button"
      class="nav-toggle flex h-10 w-10 shrink-0 flex-col items-center justify-center gap-1.5 rounded-lg border border-stone/50 bg-white shadow-soft lg:hidden"
      aria-expanded="false"
      aria-controls="main-nav"
      aria-label="Toggle navigation"
    >
      <span class="block h-0.5 w-5 bg-navy"></span>
      <span class="block h-0.5 w-5 bg-navy"></span>
      <span class="block h-0.5 w-5 bg-navy"></span>
    </button>

    <nav
      id="main-nav"
      class="main-nav absolute left-0 right-0 top-full hidden max-h-[calc(100vh-5rem)] overflow-y-auto border-b border-stone/30 bg-warm-gray px-5 py-4 lg:static lg:flex lg:max-h-none lg:flex-1 lg:items-center lg:justify-end lg:gap-6 lg:overflow-visible lg:border-0 lg:bg-transparent lg:p-0 xl:gap-8"
      aria-label="Main"
    >
      <div class="mb-4 lg:hidden">
        <Button href="/contact/" class="w-full justify-center">Plan a Gifting Program</Button>
      </div>

      <ul class="mb-4 space-y-1 lg:mb-0 lg:flex lg:items-center lg:gap-5 xl:gap-6">
        {
          navPrimary.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'block rounded-md px-2 py-2 text-sm font-medium no-underline lg:py-0',
                  currentPath.startsWith(href)
                    ? 'text-navy'
                    : 'text-ink hover:text-navy-light',
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
        {navDropdowns.map((menu) => <NavDropdown menu={menu} currentPath={currentPath} />)}
      </ul>
    </nav>

    <div class="hidden shrink-0 lg:block">
      <Button href="/contact/">Plan a Gifting Program</Button>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var toggle = document.querySelector('.nav-toggle');
    var nav = document.querySelector('.main-nav');
    if (!toggle || !nav) return;

    toggle.addEventListener('click', function () {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('hidden');
      nav.classList.toggle('block');
    });

    nav.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        if (window.innerWidth >= 1024) return;
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.add('hidden');
        nav.classList.remove('block');
      });
    });

    nav.querySelectorAll('.nav-dropdown button').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (window.innerWidth >= 1024) return;
        var panel = btn.nextElementSibling;
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        if (panel) panel.classList.toggle('hidden');
      });
    });
  })();
</script>

<style>
  @media (min-width: 1024px) {
    .main-nav {
      display: flex !important;
    }

    .nav-dropdown-panel {
      opacity: 0;
      visibility: hidden;
      transform: translateY(0.5rem);
      transition:
        opacity 0.2s ease,
        transform 0.2s ease,
        visibility 0.2s;
      pointer-events: none;
    }

    .nav-dropdown:hover .nav-dropdown-panel,
    .nav-dropdown:focus-within .nav-dropdown-panel {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: auto;
    }
  }

  @media (max-width: 1023px) {
    .nav-dropdown-panel.hidden {
      display: none;
    }

    .nav-dropdown-panel:not(.hidden) {
      display: block;
    }

    .nav-dropdown-panel {
      display: none;
    }
  }
</style>
