---
import Button from './Button.astro';
import { site } from '@/lib/site';

interface Props {
  title: string;
  description: string;
  href?: string;
  buttonLabel?: string;
}

const {
  title,
  description,
  href = '/contact/',
  buttonLabel = 'Plan a Gifting Program',
}: Props = Astro.props;
---

<section class="relative overflow-hidden bg-navy-depth py-20 text-white sm:py-24">
  <div
    class="pointer-events-none absolute inset-0 opacity-30"
    aria-hidden="true"
  >
    <svg class="h-full w-full text-gold/40" viewBox="0 0 800 200" preserveAspectRatio="none">
      <path
        d="M0 100 Q200 60 400 100 T800 100"
        fill="none"
        stroke="currentColor"
        stroke-width="1"></path>
    </svg>
  </div>
  <div class="container-content relative max-w-2xl text-center">
    <p class="mb-4 eyebrow text-gold-light">Start here</p>
    <h2 class="mb-4 text-3xl text-white sm:text-4xl">{title}</h2>
    <p class="mb-8 text-lg leading-relaxed text-white/75">{description}</p>
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <Button href={href} variant="inverse">{buttonLabel}</Button>
      <a
        href={site.bookingUrl}
        class="text-sm font-semibold text-white/75 no-underline transition-colors hover:text-gold-light"
      >
        Or book a call →
      </a>
    </div>
    <slot />
  </div>
</section>
