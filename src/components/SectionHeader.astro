---
interface Props {
  title: string;
  description?: string;
  centered?: boolean;
  class?: string;
}

const { title, description, centered = false, class: className = '' }: Props = Astro.props;
---

<div class:list={['mb-10 max-w-2xl', centered && 'mx-auto text-center', className]}>
  <h2 class="mb-3 text-3xl sm:text-4xl">{title}</h2>
  {description && <p class="text-muted">{description}</p>}
</div>
