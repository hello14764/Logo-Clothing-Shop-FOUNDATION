---
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  centered?: boolean;
  accent?: boolean;
  class?: string;
}

const {
  title,
  description,
  eyebrow,
  centered = false,
  accent = false,
  class: className = '',
}: Props = Astro.props;
---

<div class:list={['mb-12 max-w-2xl', centered && 'mx-auto text-center', className]}>
  {eyebrow && (
    <p class:list={['mb-3 eyebrow-line', centered && 'justify-center']}>{eyebrow}</p>
  )}
  <h2 class:list={['mb-4 text-3xl sm:text-4xl', accent && !centered && 'heading-accent']}>
    {title}
  </h2>
  {description && <p class="text-lg leading-relaxed text-muted">{description}</p>}
</div>
