---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'inverse' | 'ghost';
  class?: string;
}

const { href, variant = 'primary', class: className = '' }: Props = Astro.props;

const base =
  'group inline-flex items-center justify-center gap-2 rounded-lg border px-6 py-3 text-sm font-semibold no-underline transition-all duration-200';

const variants = {
  primary:
    'border-navy bg-navy text-white shadow-soft hover:-translate-y-px hover:border-navy-dark hover:bg-navy-dark hover:shadow-card',
  secondary:
    'border-stone-dark/80 bg-white/90 text-navy shadow-soft backdrop-blur-sm hover:border-gold/60 hover:bg-white hover:shadow-card',
  inverse:
    'border-white bg-white text-navy shadow-card hover:-translate-y-px hover:border-warm-gray hover:bg-warm-gray',
  ghost:
    'border-transparent bg-transparent text-navy underline-offset-4 hover:text-gold-dark hover:underline',
};
---

<a href={href} class:list={[base, variants[variant], className]}>
  <slot />
  {
    variant === 'primary' && (
      <svg
        class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5"
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M3 8h10M9 4l4 4-4 4"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    )
  }
</a>
