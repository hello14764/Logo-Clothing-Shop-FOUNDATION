---
interface Props {
  tag?: string;
  title: string;
  class?: string;
  featured?: boolean;
}

const { tag, title, class: className = '', featured = false }: Props = Astro.props;
---

<article
  class:list={[
    featured ? 'surface-card-featured pl-7' : 'surface-card-hover',
    className,
  ]}
>
  {tag && <p class="mb-2 eyebrow">{tag}</p>}
  <h3 class="mb-3 text-xl text-navy">{title}</h3>
  <div class="text-muted [&_p]:leading-relaxed [&_p]:text-muted">
    <slot />
  </div>
</article>
