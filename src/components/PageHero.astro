---
import ImagePlaceholder from './ImagePlaceholder.astro';

interface Props {
  title: string;
  lead?: string;
  tag?: string;
  visual?: boolean;
}

const { title, lead, tag, visual = false }: Props = Astro.props;
---

<section class="relative overflow-hidden border-b border-stone/30 bg-white py-16 sm:py-24">
  <div class="pointer-events-none absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
  <div class="container-content relative">
    <div class:list={['max-w-3xl', visual && 'grid items-center gap-10 lg:max-w-none lg:grid-cols-2 lg:gap-16']}>
      <div>
        {tag && <p class="mb-4 eyebrow-line">{tag}</p>}
        <h1 class="mb-5 text-4xl sm:text-5xl lg:text-[3.25rem] lg:leading-[1.1]">{title}</h1>
        {lead && <p class="text-lg leading-relaxed text-muted sm:text-xl">{lead}</p>}
        <slot />
      </div>
      {visual && <ImagePlaceholder variant="hero" />}
    </div>
  </div>
</section>
