---
interface Props {
  title: string;
  lead?: string;
  tag?: string;
}

const { title, lead, tag }: Props = Astro.props;
---

<section class="border-b border-stone/40 bg-white py-16 sm:py-20">
  <div class="container-content max-w-3xl">
    {tag && (
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-gold">{tag}</p>
    )}
    <h1 class="mb-4 text-4xl sm:text-5xl">{title}</h1>
    {lead && <p class="text-lg text-muted">{lead}</p>}
    <slot />
  </div>
</section>
