---
import { site } from '@/lib/site';

const placeholders = [1, 2, 3];
---

<section class="border-y border-stone/25 bg-white py-16 sm:py-20">
  <div class="container-content">
    <div class="mx-auto mb-10 max-w-2xl text-center">
      <p class="mb-3 eyebrow-line justify-center">Client feedback</p>
      <h2 class="mb-4 text-3xl sm:text-4xl">What clients say</h2>
      <div class="mb-3 flex items-center justify-center gap-1 text-gold" aria-label="5 out of 5 stars">
        {
          [1, 2, 3, 4, 5].map(() => (
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))
        }
      </div>
      <p class="text-sm text-muted">
        Rated 5 on Google ·
        <a
          href={site.googleReviewsUrl}
          class="font-semibold text-navy no-underline hover:text-gold-dark"
          target="_blank"
          rel="noopener noreferrer"
        >
          Read reviews
        </a>
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {
        placeholders.map((n) => (
          <article class="surface-card flex min-h-[180px] flex-col justify-between text-center">
            <div class="mx-auto mb-4 flex gap-0.5 text-gold/40" aria-hidden="true">
              {[1, 2, 3, 4, 5].map(() => (
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-sm italic text-muted/80">Review {n} — paste from Google when ready</p>
            <p class="mt-4 text-xs font-medium text-muted">Client name · Company</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
