---
import ImagePlaceholder from './ImagePlaceholder.astro';

interface Props {
  href: string;
  title: string;
  teaser: string;
  imageVariant?: 'card' | 'square';
}

const { href, title, teaser, imageVariant = 'card' }: Props = Astro.props;
---

<a href={href} class="group surface-card-hover block overflow-hidden p-0 no-underline">
  <ImagePlaceholder variant={imageVariant} class="rounded-none border-0 shadow-none" />
  <div class="p-6">
    <h3 class="mb-2 text-xl text-navy group-hover:text-gold-dark">{title}</h3>
    <p class="mb-4 text-sm leading-relaxed text-muted">{teaser}</p>
    <span class="text-sm font-semibold text-navy group-hover:text-gold-dark">
      Learn more <span aria-hidden="true">→</span>
    </span>
  </div>
</a>
