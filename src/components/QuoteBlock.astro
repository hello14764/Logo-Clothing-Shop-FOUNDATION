---
interface Props {
  text?: string;
  name?: string;
  title?: string;
  placeholder?: boolean;
}

const { text, name, title, placeholder = false }: Props = Astro.props;
---

<blockquote
  class:list={[
    'relative rounded-xl border border-stone/40 bg-white p-8 shadow-soft',
    placeholder && 'border-dashed bg-warm-gray/50',
  ]}
>
  <div class="mb-4 text-gold" aria-hidden="true">
    <svg class="h-8 w-8 opacity-60" viewBox="0 0 32 32" fill="currentColor">
      <path d="M10 8c-3.3 0-6 2.7-6 6v8h10V14H8c0-2.2 1.8-4 4-4V8zm14 0c-3.3 0-6 2.7-6 6v8h10V14h-6c0-2.2 1.8-4 4-4V8z" />
    </svg>
  </div>
  {
    placeholder || !text ? (
      <p class="text-lg italic text-muted">Client quote — add from email when ready</p>
    ) : (
      <>
        <p class="text-lg leading-relaxed text-ink">&ldquo;{text}&rdquo;</p>
        {(name || title) && (
          <footer class="mt-4 text-sm font-medium not-italic text-muted">
            {name}
            {name && title && ', '}
            {title}
          </footer>
        )}
      </>
    )
  }
</blockquote>
